{
  "name": "tulpo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:backend": "bun run --filter @tulpo/backend dev",
    "dev:frontend": "bun run --filter @tulpo/frontend dev",
    "build": "bun run --filter '*' build",
    "check": "bun run --filter '*' check",
    "db:migrate": "bun run --filter @tulpo/db migrate"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
